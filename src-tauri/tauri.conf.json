{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracey",
  "version": "0.1.0",
  "identifier": "com.vincentverweij.tracey",
  "build": {
    "frontendDist": "../src/Tracey.App/bin/Release/net10.0/publish/wwwroot",
    "devUrl": "http://localhost:5000",
    "beforeDevCommand": "dotnet watch run --project src/Tracey.App --urls http://localhost:5000",
    "beforeBuildCommand": "dotnet publish src/Tracey.App -c Release -o src/Tracey.App/bin/Release/net10.0/publish"
  },
  "app": {
    "windows": [
      {
        "title": "Tracey",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
