{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracey",
  "version": "0.1.0",
  "identifier": "com.vincentverweij.tracey",
  "build": {
    "frontendDist": "../src/Tracey.App/bin/Release/net10.0/publish/wwwroot",
    "devUrl": "http://localhost:5000",
    "beforeDevCommand": {
      "script": "dotnet watch run --project ../src/Tracey.App --urls http://localhost:5000",
      "cwd": "."
    },
    "beforeBuildCommand": {
      "script": "dotnet publish ../src/Tracey.App -c Release -o ../src/Tracey.App/bin/Release/net10.0/publish",
      "cwd": "."
    }
  },
  "app": {
    "windows": [
      {
        "title": "Tracey",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://asset.localhost https://asset.localhost; connect-src 'self' tauri: asset: http://asset.localhost https://asset.localhost https://api.telegram.org",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
