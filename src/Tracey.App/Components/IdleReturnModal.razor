@inject TauriIpcService Tauri

@if (_isVisible)
{
    <div class="idle-modal-backdrop"
         role="dialog"
         aria-modal="true"
         aria-labelledby="idle-modal-title"
         aria-describedby="idle-modal-desc">
        <div class="idle-modal">
            <div class="idle-modal-header">
                <h2 id="idle-modal-title" class="idle-modal-title">@_durationText</h2>
                <p id="idle-modal-desc" class="idle-modal-description">What should we do with that time?</p>
            </div>

            @if (_showSpecifyInput)
            {
                <div class="specify-form">
                    <label for="specify-desc">What were you doing?</label>
                    <input id="specify-desc"
                           type="text"
                           @bind="_specifyDescription"
                           @ref="_specifyInputRef"
                           aria-label="What were you doing?"
                           placeholder="e.g. Reviewing architecture docs"
                           @onkeydown="@(async (e) => { if (e.Key == "Enter") await SubmitSpecify(); })" />
                    @if (!string.IsNullOrEmpty(_specifyError)) { <p class="specify-error" role="alert">@_specifyError</p> }
                    <div class="specify-actions">
                        <BbButton OnClick="SubmitSpecify">Save</BbButton>
                        <BbButton Variant="ButtonVariant.Outline"
                                  OnClick="@(() => { _showSpecifyInput = false; })">Back</BbButton>
                    </div>
                </div>
            }
            else
            {
                <div class="idle-options" role="group" aria-label="What happened while you were away?">
                    <button type="button" class="idle-option-btn" @onclick='() => Resolve("break")'>
                        <span class="option-label">Break</span>
                        <span class="option-hint">Stop timer here, add a break</span>
                    </button>
                    <button type="button" class="idle-option-btn" @onclick='() => Resolve("meeting")'>
                        <span class="option-label">Meeting</span>
                        <span class="option-hint">Log as a meeting</span>
                    </button>
                    <button type="button" class="idle-option-btn" @onclick="ShowSpecifyInput">
                        <span class="option-label">Specify…</span>
                        <span class="option-hint">Describe what you were doing</span>
                    </button>
                    <button type="button" class="idle-option-btn" @onclick='() => Resolve("keep")'>
                        <span class="option-label">Keep running</span>
                        <span class="option-hint">Continue the current timer</span>
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnResolved { get; set; }

    private bool _isVisible = false;
    private bool _showSpecifyInput = false;
    private string _specifyDescription = string.Empty;
    private string _specifyError = string.Empty;
    private ElementReference _specifyInputRef;
    private string _idleStartedAt = string.Empty;
    private string _idleEndedAt = string.Empty;
    private string _durationText = string.Empty;

    /// Called by Dashboard when tracey://idle-detected fires.
    public void Show(string idleSince)
    {
        Console.WriteLine($"[IdleReturnModal] Show() EXECUTING: idleSince={idleSince} _isVisible was {_isVisible}");
        _idleStartedAt = idleSince;
        _idleEndedAt = DateTime.UtcNow.ToString("o");
        _isVisible = true;
        _showSpecifyInput = false;
        _specifyDescription = string.Empty;

        if (DateTime.TryParse(idleSince, null,
            System.Globalization.DateTimeStyles.RoundtripKind, out var start))
        {
            var duration = DateTime.UtcNow - start;
            _durationText = duration.TotalMinutes >= 60
                ? $"You were away for {(int)duration.TotalHours}h {duration.Minutes}m"
                : $"You were away for {(int)duration.TotalMinutes} minute{((int)duration.TotalMinutes == 1 ? "" : "s")}";
        }
        else
        {
            _durationText = "You were away for a while";
        }

        Console.WriteLine($"[IdleReturnModal] Show() complete: _isVisible={_isVisible}, calling StateHasChanged()");
        StateHasChanged();
    }

    private async Task Resolve(string resolution)
    {
        try
        {
            await Tauri.IdleResolveAsync(new IdleResolveRequest(
                resolution,
                _idleStartedAt,
                _idleEndedAt,
                null
            ));
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[IdleModal] idle_resolve failed: {ex.Message}");
        }
        finally
        {
            _isVisible = false;
            await OnResolved.InvokeAsync();
        }
    }

    private bool _pendingFocusSpecify = false;

    private void ShowSpecifyInput()
    {
        _specifyError = string.Empty;
        _showSpecifyInput = true;
        _pendingFocusSpecify = true;
        // Focus is deferred to OnAfterRenderAsync — the input doesn't exist in the DOM
        // until _showSpecifyInput = true has been applied by the next render cycle.
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingFocusSpecify)
        {
            _pendingFocusSpecify = false;
            try { await _specifyInputRef.FocusAsync(); }
            catch { /* silently ignore if the ref is not yet assigned */ }
        }
    }

    private async Task SubmitSpecify()
    {
        _specifyError = string.Empty;
        if (string.IsNullOrWhiteSpace(_specifyDescription))
        {
            _specifyError = "Please describe what you were doing.";
            return;
        }

        try
        {
            await Tauri.IdleResolveAsync(new IdleResolveRequest(
                "specify",
                _idleStartedAt,
                _idleEndedAt,
                new IdleEntryDetails(_specifyDescription, null, null, [])
            ));
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[IdleModal] specify resolve failed: {ex.Message}");
        }
        finally
        {
            _isVisible = false;
            _showSpecifyInput = false;
            await OnResolved.InvokeAsync();
        }
    }

}
