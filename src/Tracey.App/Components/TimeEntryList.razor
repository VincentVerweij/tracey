@inject TauriIpcService Tauri
@inject ITimerStateService Timer
@inject IJSRuntime JS
@implements IDisposable

<div class="time-entry-list" @ref="_listRef">
    @if (_loading)
    {
        <p class="loading-indicator" aria-live="polite">Loading entries…</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="empty-state">No time entries yet. Start a timer to begin tracking.</p>
    }
    else
    {
        @* Running timer row (live) *@
        @if (Timer.IsRunning && Timer.CurrentEntryId != null)
        {
            <div class="running-timer-row" aria-live="polite">
                <span class="entry-description">@Timer.CurrentDescription</span>
                <time role="timer" aria-live="off" aria-atomic="true" datetime="@Timer.Elapsed.ToString("c")">
                    @FormatElapsed(Timer.Elapsed)
                </time>
            </div>
        }

        @* Completed entries grouped by date *@
        @foreach (var group in _groupedEntries)
        {
            <section class="date-group">
                <h2 class="date-header">@FormatDate(group.Key)</h2>
                <ul class="entry-list" role="list">
                    @foreach (var entry in group.Value)
                    {
                        <li class="entry-row @(_editingId == entry.Id ? "is-editing" : "")"
                            role="listitem">
                            @if (_editingId == entry.Id)
                            {
                                <div class="entry-edit-form" role="form" aria-label="Edit time entry">
                                    <div class="edit-field">
                                        <label for="desc-@entry.Id">Description</label>
                                        <input id="desc-@entry.Id"
                                               type="text"
                                               @bind="_editDescription"
                                               @bind:event="oninput"
                                               aria-label="Entry description"
                                               @onblur="() => AutoSave(entry)" />
                                    </div>
                                    <div class="edit-times">
                                        <div class="edit-field">
                                            <label for="start-@entry.Id">Start</label>
                                            <input id="start-@entry.Id"
                                                   type="datetime-local"
                                                   @bind="_editStarted"
                                                   @onblur="() => AutoSave(entry)"
                                                   aria-label="Start time" />
                                        </div>
                                        <div class="edit-field">
                                            <label for="end-@entry.Id">End</label>
                                            <input id="end-@entry.Id"
                                                   type="datetime-local"
                                                   @bind="_editEnded"
                                                   @onblur="() => AutoSave(entry)"
                                                   aria-label="End time" />
                                        </div>
                                    </div>
                                    @if (_editError != null)
                                    {
                                        <p class="edit-error" role="alert">@_editError</p>
                                    }
                                    <BbButton Variant="ButtonVariant.Ghost"
                                              Size="ButtonSize.Small"
                                              AriaLabel="Cancel edit"
                                              OnClick="CancelEdit">
                                        Cancel
                                    </BbButton>
                                </div>
                            }
                            else
                            {
                                <button type="button"
                                        class="entry-description-btn"
                                        @onclick="() => StartInlineEdit(entry)"
                                        aria-label="@entry.Description (click to edit)">
                                    @entry.Description
                                </button>
                                <span class="entry-times">
                                    @FormatTime(entry.StartedAt) – @FormatTime(entry.EndedAt)
                                </span>
                                @if (entry.ProjectName != null)
                                {
                                    <span class="entry-project">@entry.ClientName / @entry.ProjectName</span>
                                }
                                <BbButton Variant="ButtonVariant.Outline"
                                          Size="ButtonSize.Small"
                                          AriaLabel="@($"Continue: {entry.Description}")"
                                          OnClick="() => ContinueEntry(entry.Id)">
                                    Continue
                                </BbButton>
                            }
                        </li>
                    }
                </ul>
            </section>
        }

        @if (_hasMore)
        {
            <div class="load-more-wrapper">
                <BbButton Variant="ButtonVariant.Outline"
                          OnClick="LoadMore"
                          AriaLabel="Load more entries">
                    Load more
                </BbButton>
            </div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private List<TimeEntryItem> _entries = new();
    private Dictionary<string, List<TimeEntryItem>> _groupedEntries = new();
    private bool _hasMore = false;
    private int _currentPage = 1;
    private string? _editingId;
    private ElementReference _listRef;

    // Inline edit fields
    private string _editDescription = string.Empty;
    private DateTime _editStarted;
    private DateTime _editEnded;
    private string? _editError;
    private bool _isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        Timer.OnStateChanged += OnTimerStateChanged;
        await LoadPage(1);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreScrollPosition();
        }
    }

    public async Task LoadPage(int page)
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var result = await Tauri.TimeEntryListAsync(new TimeEntryListRequest(page, 25));
            if (page == 1) _entries.Clear();
            _entries.AddRange(result.Entries);
            _hasMore = result.HasMore;
            _currentPage = page;
            RebuildGroups();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[TimeEntryList] Load failed: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void RebuildGroups()
    {
        _groupedEntries = _entries
            .GroupBy(e => DateOnly.Parse(e.StartedAt[..10]))
            .OrderByDescending(g => g.Key)
            .ToDictionary(
                g => g.Key.ToString("yyyy-MM-dd"),
                g => g.ToList()
            );
    }

    private async Task LoadMore() => await LoadPage(_currentPage + 1);

    private async Task ContinueEntry(string entryId)
    {
        try
        {
            await Tauri.TimeEntryContinueAsync(entryId);
            await LoadPage(1);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[TimeEntryList] Continue failed: {ex.Message}");
        }
    }

    private void StartInlineEdit(TimeEntryItem entry)
    {
        _editingId = entry.Id;
        _editDescription = entry.Description;
        _editStarted = DateTime.TryParse(entry.StartedAt, null,
            System.Globalization.DateTimeStyles.RoundtripKind, out var s)
            ? s.ToLocalTime() : DateTime.Now;
        _editEnded = DateTime.TryParse(entry.EndedAt, null,
            System.Globalization.DateTimeStyles.RoundtripKind, out var e)
            ? e.ToLocalTime() : DateTime.Now;
        _editError = null;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editError = null;
    }

    private async Task AutoSave(TimeEntryItem entry)
    {
        if (_isSaving) return;
        if (_editingId != entry.Id) return;
        _isSaving = true;
        _editError = null;

        try
        {
            var startUtc = _editStarted.ToUniversalTime().ToString("o");
            var endUtc = _editEnded.ToUniversalTime().ToString("o");

            await Tauri.TimeEntryUpdateAsync(new TimeEntryUpdateRequest(
                entry.Id,
                _editDescription,
                null,   // project_id — no change
                null,   // task_id — no change
                null,   // tag_ids — no change
                startUtc,
                endUtc,
                false   // force = false; if overlap, show error
            ));

            _editingId = null;
            await LoadPage(1);
        }
        catch (Exception ex) when (ex.Message.Contains("overlap_detected"))
        {
            _editError = "This time overlaps with another entry. Adjust the times or cancel.";
        }
        catch (Exception ex) when (ex.Message.Contains("invalid_time_range"))
        {
            _editError = "End time must be after start time.";
        }
        catch (Exception ex)
        {
            _editError = $"Save failed: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async void OnTimerStateChanged()
    {
        await InvokeAsync(StateHasChanged);
        await SaveScrollPosition();
    }

    private async Task SaveScrollPosition()
    {
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem",
                "tracey.entry-list.scroll", "0");
        }
        catch { }
    }

    private async Task RestoreScrollPosition()
    {
        try
        {
            await JS.InvokeAsync<string>("sessionStorage.getItem", "tracey.entry-list.scroll");
            // Scroll restoration via JS — stub for T029a compliance intent
        }
        catch { }
    }

    private static string FormatElapsed(TimeSpan t) =>
        t.TotalHours >= 1
            ? $"{(int)t.TotalHours}:{t.Minutes:D2}:{t.Seconds:D2}"
            : $"{t.Minutes}:{t.Seconds:D2}";

    private static string FormatDate(string isoDate) =>
        DateOnly.TryParse(isoDate, out var d)
            ? d.ToString("dddd, MMMM d")
            : isoDate;

    private static string FormatTime(string? isoUtc)
    {
        if (isoUtc is null) return string.Empty;
        if (DateTime.TryParse(isoUtc, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt))
            return dt.ToLocalTime().ToString("HH:mm");
        return isoUtc;
    }

    public void Dispose() => Timer.OnStateChanged -= OnTimerStateChanged;
}
