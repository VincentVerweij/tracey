@page "/dashboard"
@page "/"
@inject ITimerStateService Timer
@inject TauriEventService Events
@implements IDisposable

<PageTitle>Tracey</PageTitle>

<div class="dashboard">
    <div class="dashboard-header">
        <h1 class="page-title">Today</h1>
        <span class="page-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
    </div>
    <QuickEntryBar OnTimerStarted="RefreshList" OnTimerStopped="RefreshList" />
    <TimeEntryList @ref="_entryList" />
</div>

<IdleReturnModal @ref="_idleModal" OnResolved="HandleIdleResolved" />

@code {
    private TimeEntryList? _entryList;
    private IdleReturnModal? _idleModal;

    protected override async Task OnInitializedAsync()
    {
        if (Timer is TimerStateService ts)
            await ts.InitializeAsync();

        Events.OnIdleDetected += HandleIdleDetected;
    }

    private void HandleIdleDetected(IdleDetectedPayload payload)
    {
        if (!payload.HadActiveTimer) return;

        InvokeAsync(() =>
        {
            _idleModal?.Show(payload.IdleSince);
            StateHasChanged();
        });
    }

    private async Task HandleIdleResolved()
    {
        await RefreshList();
    }

    private async Task RefreshList()
    {
        if (_entryList != null)
            await _entryList.LoadPage(1);
    }

    public void Dispose()
    {
        Events.OnIdleDetected -= HandleIdleDetected;
    }
}
