@page "/projects"
@inject TauriIpcService Tauri

<PageTitle>Projects</PageTitle>

<div class="projects-page">
    <div class="projects-header">
        <h1>Projects</h1>
        <div class="projects-toolbar">
            <label class="show-archived-label">
                <input type="checkbox"
                       @bind="_showArchived"
                       @bind:after="LoadClients" />
                Show archived
            </label>
            <button type="button"
                    @onclick='() => _showAddClient = !_showAddClient'
                    aria-label="Add client">+ Add Client</button>
        </div>
    </div>

    @if (_errorMessage != null)
    {
        <div role="alert" class="alert alert-danger">
            @_errorMessage
            <button type="button"
                    aria-label="Dismiss error"
                    @onclick='() => _errorMessage = null'>&#x2715;</button>
        </div>
    }

    @if (_showAddClient)
    {
        <div class="add-client-form">
            <h3>New Client</h3>
            <div class="form-group">
                <label for="new-client-name">Name</label>
                <input id="new-client-name"
                       type="text"
                       @bind="_newClientName"
                       placeholder="Client name"
                       aria-label="Client name" />
            </div>
            <div class="form-group">
                <label for="new-client-color">Color</label>
                <input id="new-client-color"
                       type="color"
                       @bind="_newClientColor"
                       aria-label="Client color" />
            </div>
            <div class="form-group">
                <label for="new-client-logo">Logo path (optional)</label>
                <input id="new-client-logo"
                       type="text"
                       @bind="_newClientLogoPath"
                       placeholder="C:\path\to\logo.png"
                       aria-label="Logo path" />
            </div>
            <div class="form-actions">
                <button type="button"
                        class="btn-primary"
                        @onclick="SaveNewClient"
                        aria-label="Save client">Save</button>
                <button type="button"
                        class="btn-secondary"
                        @onclick="CancelAddClient"
                        aria-label="Cancel add client">Cancel</button>
            </div>
        </div>
    }

    @if (_loading)
    {
        <p class="loading-text">Loading...</p>
    }
    else if (_clients.Count == 0)
    {
        <p class="empty-state">No clients yet. Add your first client above.</p>
    }
    else
    {
        <div class="client-list">
            @foreach (var client in _clients)
            {
                var isClientExpanded = _expandedClients.Contains(client.Id);
                <div class="client-card @(client.IsArchived ? "archived" : "")">

                    <div class="client-header">
                        <button type="button"
                                class="chevron-btn"
                                @onclick="() => ToggleClientExpand(client.Id)"
                                aria-label="@ExpandLabel(isClientExpanded, client.Name)"
                                aria-expanded="@isClientExpanded.ToString().ToLower()">
                            @(isClientExpanded ? "▼" : "▶")
                        </button>
                        <span class="color-swatch"
                              style="background: @client.Color; width:1rem; height:1rem; display:inline-block; border-radius:50%;"
                              aria-label="color swatch"></span>
                        <span class="client-name">@client.Name</span>
                        @if (client.IsArchived)
                        {
                            <span class="archive-badge">Archived</span>
                        }
                        <div class="client-actions">
                            @if (client.IsArchived)
                            {
                                <button type="button" class="btn-sm"
                                        @onclick="() => UnarchiveClient(client.Id)"
                                        aria-label="@($"Unarchive {client.Name}")">Unarchive</button>
                            }
                            else
                            {
                                <button type="button" class="btn-sm"
                                        @onclick="() => ArchiveClient(client.Id)"
                                        aria-label="@($"Archive {client.Name}")">Archive</button>
                            }
                            <button type="button" class="btn-sm btn-danger"
                                    @onclick="() => ConfirmDeleteClient(client)"
                                    aria-label="@($"Delete {client.Name}")">Delete</button>
                        </div>
                    </div>

                    @if (_pendingDeleteClient?.Id == client.Id)
                    {
                        <div role="dialog"
                             aria-label="@($"Confirm delete {client.Name}")"
                             class="inline-confirm">
                            <p>Are you sure? This will delete all projects and tasks under <strong>@client.Name</strong>. Orphaned time entries will be detached.</p>
                            <div class="form-actions">
                                <button type="button" class="btn-danger"
                                        @onclick="() => DeleteClient(client.Id)"
                                        aria-label="@($"Confirm delete {client.Name}")">Confirm Delete</button>
                                <button type="button" class="btn-secondary"
                                        @onclick='() => _pendingDeleteClient = null'
                                        aria-label="Cancel delete">Cancel</button>
                            </div>
                        </div>
                    }

                    @if (isClientExpanded)
                    {
                        <div class="project-list">
                            @if (_projectsLoading.Contains(client.Id))
                            {
                                <p class="loading-text">Loading projects...</p>
                            }
                            else if (_projects.TryGetValue(client.Id, out var projects))
                            {
                                @if (projects.Count == 0)
                                {
                                    <p class="empty-state">No projects yet.</p>
                                }
                                @foreach (var project in projects)
                                {
                                    var isProjectExpanded = _expandedProjects.Contains(project.Id);
                                    <div class="project-row @(project.IsArchived ? "archived" : "")">

                                        <div class="project-header">
                                            <button type="button"
                                                    class="chevron-btn"
                                                    @onclick="() => ToggleProjectExpand(project.Id)"
                                                    aria-label="@ExpandLabel(isProjectExpanded, project.Name)"
                                                    aria-expanded="@isProjectExpanded.ToString().ToLower()">
                                                @(isProjectExpanded ? "▼" : "▶")
                                            </button>
                                            <span class="project-name">@project.Name</span>
                                            @if (project.IsArchived)
                                            {
                                                <span class="archive-badge">Archived</span>
                                            }
                                            <div class="project-actions">
                                                @if (project.IsArchived)
                                                {
                                                    <button type="button" class="btn-sm"
                                                            @onclick="() => UnarchiveProject(project.Id, client.Id)"
                                                            aria-label="@($"Unarchive {project.Name}")">Unarchive</button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn-sm"
                                                            @onclick="() => ArchiveProject(project.Id, client.Id)"
                                                            aria-label="@($"Archive {project.Name}")">Archive</button>
                                                }
                                                <button type="button" class="btn-sm btn-danger"
                                                        @onclick="() => ConfirmDeleteProject(project)"
                                                        aria-label="@($"Delete {project.Name}")">Delete</button>
                                            </div>
                                        </div>

                                        @if (_pendingDeleteProject?.Id == project.Id)
                                        {
                                            <div role="dialog"
                                                 aria-label="@($"Confirm delete {project.Name}")"
                                                 class="inline-confirm">
                                                <p>Are you sure? Deleting <strong>@project.Name</strong> will also delete its tasks. Orphaned time entries will be detached.</p>
                                                <div class="form-actions">
                                                    <button type="button" class="btn-danger"
                                                            @onclick="() => DeleteProject(project.Id, client.Id)"
                                                            aria-label="@($"Confirm delete {project.Name}")">Confirm Delete</button>
                                                    <button type="button" class="btn-secondary"
                                                            @onclick='() => _pendingDeleteProject = null'
                                                            aria-label="Cancel delete">Cancel</button>
                                                </div>
                                            </div>
                                        }

                                        @if (isProjectExpanded)
                                        {
                                            <div class="task-list">
                                                @if (_tasksLoading.Contains(project.Id))
                                                {
                                                    <p class="loading-text">Loading tasks...</p>
                                                }
                                                else if (_tasks.TryGetValue(project.Id, out var tasks))
                                                {
                                                    @if (tasks.Count == 0)
                                                    {
                                                        <p class="empty-state">No tasks yet.</p>
                                                    }
                                                    @foreach (var task in tasks)
                                                    {
                                                        <div class="task-row">
                                                            <span class="task-name">@task.Name</span>
                                                            <button type="button" class="btn-sm btn-danger"
                                                                    @onclick="() => DeleteTask(task.Id, project.Id)"
                                                                    aria-label="@($"Delete task {task.Name}")">Delete</button>
                                                        </div>
                                                    }
                                                }
                                                @if (_showAddTask.TryGetValue(project.Id, out var showTask) && showTask)
                                                {
                                                    <div class="add-task-form">
                                                        <input type="text"
                                                               @bind="_newTaskName[project.Id]"
                                                               placeholder="Task name"
                                                               aria-label="New task name for @project.Name" />
                                                        <button type="button" class="btn-primary"
                                                                @onclick="() => SaveNewTask(project.Id)"
                                                                aria-label="Save task">Save</button>
                                                        <button type="button" class="btn-secondary"
                                                                @onclick="() => HideAddTask(project.Id)"
                                                                aria-label="Cancel add task">Cancel</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn-sm"
                                                            @onclick="() => ShowAddTask(project.Id)"
                                                            aria-label="@($"Add task to {project.Name}")">+ Add Task</button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }

                            @if (_showAddProject.TryGetValue(client.Id, out var showProject) && showProject)
                            {
                                <div class="add-project-form">
                                    <input type="text"
                                           @bind="_newProjectName[client.Id]"
                                           placeholder="Project name"
                                           aria-label="New project name for @client.Name" />
                                    <button type="button" class="btn-primary"
                                            @onclick="() => SaveNewProject(client.Id)"
                                            aria-label="Save project">Save</button>
                                    <button type="button" class="btn-secondary"
                                            @onclick="() => HideAddProject(client.Id)"
                                            aria-label="Cancel add project">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <button type="button" class="btn-sm"
                                        @onclick="() => ShowAddProject(client.Id)"
                                        aria-label="@($"Add project to {client.Name}")">+ Add Project</button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ClientItem> _clients = [];
    private Dictionary<string, List<ProjectItem>> _projects = [];
    private Dictionary<string, List<TaskItem>> _tasks = [];
    private HashSet<string> _expandedClients = [];
    private HashSet<string> _expandedProjects = [];
    private HashSet<string> _projectsLoading = [];
    private HashSet<string> _tasksLoading = [];
    private Dictionary<string, bool> _showAddProject = [];
    private Dictionary<string, bool> _showAddTask = [];
    private Dictionary<string, string> _newProjectName = [];
    private Dictionary<string, string> _newTaskName = [];

    private bool _showAddClient;
    private bool _showArchived;
    private bool _loading;
    private string? _errorMessage;

    private string _newClientName = string.Empty;
    private string _newClientColor = "#3b82f6";
    private string _newClientLogoPath = string.Empty;

    private ClientItem? _pendingDeleteClient;
    private ProjectItem? _pendingDeleteProject;

    private static string ExpandLabel(bool expanded, string name) =>
        expanded ? $"Collapse {name}" : $"Expand {name}";

    protected override async Task OnInitializedAsync() => await LoadClients();

    private async Task LoadClients()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            var result = await Tauri.ClientListAsync(_showArchived);
            _clients = [.. result.Clients];
            _projects.Clear();
            _expandedClients.Clear();
            _expandedProjects.Clear();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load clients: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleClientExpand(string clientId)
    {
        if (_expandedClients.Remove(clientId)) return;
        _expandedClients.Add(clientId);
        if (!_projects.ContainsKey(clientId))
            await LoadProjects(clientId);
    }

    private async Task LoadProjects(string clientId)
    {
        _projectsLoading.Add(clientId);
        try
        {
            var result = await Tauri.ProjectListAsync(clientId, _showArchived);
            _projects[clientId] = [.. result.Projects];
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load projects: {ex.Message}";
        }
        finally
        {
            _projectsLoading.Remove(clientId);
        }
    }

    private async Task ToggleProjectExpand(string projectId)
    {
        if (_expandedProjects.Remove(projectId)) return;
        _expandedProjects.Add(projectId);
        if (!_tasks.ContainsKey(projectId))
            await LoadTasks(projectId);
    }

    private async Task LoadTasks(string projectId)
    {
        _tasksLoading.Add(projectId);
        try
        {
            var result = await Tauri.TaskListAsync(projectId);
            _tasks[projectId] = [.. result.Tasks];
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load tasks: {ex.Message}";
        }
        finally
        {
            _tasksLoading.Remove(projectId);
        }
    }

    private async Task SaveNewClient()
    {
        if (string.IsNullOrWhiteSpace(_newClientName))
        {
            _errorMessage = "Client name is required.";
            return;
        }
        try
        {
            await Tauri.ClientCreateAsync(new ClientCreateRequest(
                _newClientName.Trim(),
                _newClientColor,
                string.IsNullOrWhiteSpace(_newClientLogoPath) ? null : _newClientLogoPath.Trim()));
            _showAddClient = false;
            ResetNewClientForm();
            await LoadClients();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to create client: {ex.Message}";
        }
    }

    private void CancelAddClient()
    {
        _showAddClient = false;
        ResetNewClientForm();
    }

    private void ResetNewClientForm()
    {
        _newClientName = string.Empty;
        _newClientColor = "#3b82f6";
        _newClientLogoPath = string.Empty;
    }

    private async Task ArchiveClient(string clientId)
    {
        try
        {
            await Tauri.ClientArchiveAsync(clientId);
            await LoadClients();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to archive client: {ex.Message}";
        }
    }

    private async Task UnarchiveClient(string clientId)
    {
        try
        {
            await Tauri.ClientUnarchiveAsync(clientId);
            await LoadClients();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to unarchive client: {ex.Message}";
        }
    }

    private void ConfirmDeleteClient(ClientItem client)
    {
        _pendingDeleteClient = client;
        _pendingDeleteProject = null;
    }

    private async Task DeleteClient(string clientId)
    {
        try
        {
            await Tauri.ClientDeleteAsync(clientId);
            _pendingDeleteClient = null;
            await LoadClients();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete client: {ex.Message}";
            _pendingDeleteClient = null;
        }
    }

    private void ShowAddProject(string clientId)
    {
        _showAddProject[clientId] = true;
        _newProjectName.TryAdd(clientId, string.Empty);
    }

    private void HideAddProject(string clientId) => _showAddProject[clientId] = false;

    private async Task SaveNewProject(string clientId)
    {
        if (!_newProjectName.TryGetValue(clientId, out var name) || string.IsNullOrWhiteSpace(name))
        {
            _errorMessage = "Project name is required.";
            return;
        }
        try
        {
            await Tauri.ProjectCreateAsync(new ProjectCreateRequest(name.Trim(), clientId));
            _showAddProject[clientId] = false;
            _newProjectName[clientId] = string.Empty;
            _projects.Remove(clientId);
            await LoadProjects(clientId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to create project: {ex.Message}";
        }
    }

    private async Task ArchiveProject(string projectId, string clientId)
    {
        try
        {
            await Tauri.ProjectArchiveAsync(projectId);
            _projects.Remove(clientId);
            await LoadProjects(clientId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to archive project: {ex.Message}";
        }
    }

    private async Task UnarchiveProject(string projectId, string clientId)
    {
        try
        {
            await Tauri.ProjectUnarchiveAsync(projectId);
            _projects.Remove(clientId);
            await LoadProjects(clientId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to unarchive project: {ex.Message}";
        }
    }

    private void ConfirmDeleteProject(ProjectItem project)
    {
        _pendingDeleteProject = project;
        _pendingDeleteClient = null;
    }

    private async Task DeleteProject(string projectId, string clientId)
    {
        try
        {
            await Tauri.ProjectDeleteAsync(projectId);
            _pendingDeleteProject = null;
            _projects.Remove(clientId);
            await LoadProjects(clientId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete project: {ex.Message}";
            _pendingDeleteProject = null;
        }
    }

    private void ShowAddTask(string projectId)
    {
        _showAddTask[projectId] = true;
        _newTaskName.TryAdd(projectId, string.Empty);
    }

    private void HideAddTask(string projectId) => _showAddTask[projectId] = false;

    private async Task SaveNewTask(string projectId)
    {
        if (!_newTaskName.TryGetValue(projectId, out var name) || string.IsNullOrWhiteSpace(name))
        {
            _errorMessage = "Task name is required.";
            return;
        }
        try
        {
            await Tauri.TaskCreateAsync(new TaskCreateRequest(name.Trim(), projectId));
            _showAddTask[projectId] = false;
            _newTaskName[projectId] = string.Empty;
            _tasks.Remove(projectId);
            await LoadTasks(projectId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to create task: {ex.Message}";
        }
    }

    private async Task DeleteTask(string taskId, string projectId)
    {
        try
        {
            await Tauri.TaskDeleteAsync(taskId);
            _tasks.Remove(projectId);
            await LoadTasks(projectId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete task: {ex.Message}";
        }
    }
}
